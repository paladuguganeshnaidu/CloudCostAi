# Copy to .env and set secure values
SECRET_KEY=replace-with-a-random-secret
# Optional: path to SQLite DB (absolute or relative)
DATABASE_PATH=cloudcostai.db
# Admin visibility and credentials (do NOT commit real secrets)
# Set SHOW_ADMIN=true to enable the admin UI and endpoints
SHOW_ADMIN=false
# Example: set ADMIN_USER and ADMIN_PASS in your deployment environment
ADMIN_USER=your_admin_username
ADMIN_PASS=your_admin_password
# INR rate adjustment for the post-model pricing engine.
# The model already predicts in INR; set this if the training-time
# USD->INR exchange rate has drifted significantly from the current rate.
# Default = 1.0 (no adjustment). Example: INR_RATE=1.05
INR_RATE=1.0
